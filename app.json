{
  "expo": {
    "name": "Coach Atlas",
    "slug": "coach-atlas-mobile",
    "scheme": "coachatlas",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.coachatlas.app"
    },
    "android": {
      "package": "com.coachatlas.app",
      "adaptiveIcon": {
        "backgroundColor": "#0F172A"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "@clerk/expo",
      "expo-web-browser"
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "7c7e32bb-ced2-466a-b414-f27aaabe21dd"
      }
    }
  }
}
