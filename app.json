{
  "expo": {
    "name": "Kaidenz",
    "slug": "coach-atlas-mobile",
    "scheme": "kaidenz",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.kaidenz.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.kaidenz.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F172A"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "@clerk/expo",
        {
          "iosUrlScheme": "com.googleusercontent.apps.30794482395-pfg9841ihmcbamshtee628643pfabp15"
        }
      ],
      "expo-web-browser",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#0F172A"
        }
      ]
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "7c7e32bb-ced2-466a-b414-f27aaabe21dd"
      },
      "EXPO_PUBLIC_CLERK_GOOGLE_WEB_CLIENT_ID": "30794482395-hjbesqafsjd2cnmbr5mstmmvq1qsr163.apps.googleusercontent.com",
      "EXPO_PUBLIC_CLERK_GOOGLE_ANDROID_CLIENT_ID": "30794482395-eul9nsii5ciocahjnr7shbrdgtjkfkra.apps.googleusercontent.com",
      "EXPO_PUBLIC_CLERK_GOOGLE_IOS_CLIENT_ID": "30794482395-pfg9841ihmcbamshtee628643pfabp15.apps.googleusercontent.com",
      "EXPO_PUBLIC_CLERK_GOOGLE_IOS_URL_SCHEME": "com.googleusercontent.apps.30794482395-pfg9841ihmcbamshtee628643pfabp15"
    },
    "icon": "./assets/icon.png"
  }
}
